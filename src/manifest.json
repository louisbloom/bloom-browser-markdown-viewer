{
  "manifest_version": 2,
  "name": "Project Bloom Markdown Viewer",
  "version": "1.3.0",
  "description": "Renders GFM markdown files in the browser with a dark, Charm-inspired theme",
  "browser_specific_settings": {
    "gecko": {
      "id": "bloom-markdown-viewer@firefox.local",
      "strict_min_version": "91.0"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "*://*/*.md",
        "*://*/*.markdown",
        "*://*/*.md?*",
        "*://*/*.markdown?*",
        "file:///*/*.md",
        "file:///*/*.markdown"
      ],
      "match_about_blank": false,
      "js": ["content.bundle.js"],
      "css": ["content.bundle.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "web_accessible_resources": [
    "vendor/mermaid-init.mjs",
    "vendor/mermaid/mermaid.esm.min.mjs",
    "vendor/mermaid/chunks/mermaid.esm.min/*"
  ]
}
